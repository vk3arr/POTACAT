{
  "name": "potacat",
  "version": "1.1.8",
  "description": "Amateur radio spot aggregator with CAT control, QSO logging, and panadapter integration",
  "author": {
    "name": "Casey Stanton",
    "email": "casey@potacat.com"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-icon": "node scripts/build-icon.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "release": "node scripts/release.js",
    "launcher": "node scripts/launcher.js",
    "launcher:install": "node scripts/launcher-install.js",
    "launcher:uninstall": "node scripts/launcher-install.js --uninstall"
  },
  "build": {
    "appId": "com.waffleslop.potacat",
    "productName": "POTACAT",
    "icon": "assets/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "preload-popout.js",
      "preload-qso-popout.js",
      "preload-actmap-popout.js",
      "preload-spots-popout.js",
      "preload-cluster-popout.js",
      "preload-jtcat-popout.js",
      "preload-remote-audio.js",
      "lib/**/*",
      "renderer/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "assets/icon-256.png",
      "assets/icon-light.png",
      "assets/cty.dat",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/sharp/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POTACAT",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "identity": null,
      "entitlements": null,
      "entitlementsInherit": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "POTACAT needs microphone access for ECHOCAT remote audio.",
        "NSCameraUsageDescription": "POTACAT does not use the camera but WebRTC requires this permission."
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility"
    },
    "protocols": [
      {
        "name": "POTACAT Protocol",
        "schemes": [
          "potacat"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "assets/hamlib",
        "to": "hamlib",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/launcher.js",
        "to": "scripts/launcher.js"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Waffleslop",
      "repo": "POTACAT"
    }
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.7.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ft8js": "^0.0.3",
    "leaflet": "^1.9.4",
    "serialport": "^13.0.0",
    "sql.js": "^1.14.0",
    "ws": "^8.19.0"
  }
}
